{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/server.js",
    "migrate:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma migrate deploy && tsx prisma/seed.ts",
    "data:all": "prisma migrate deploy && tsx prisma/seed.ts && tsx src/scripts/import-wikidata.ts && tsx src/scripts/enrich-narratives.ts && tsx src/scripts/enrich-photos.ts",
    "import:wikidata": "tsx src/scripts/import-wikidata.ts",
    "enrich:narratives": "tsx src/scripts/enrich-narratives.ts",
    "enrich:photos": "tsx src/scripts/enrich-photos.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
